{
  "name": "wordmaker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Paste Markdown, get a beautifully formatted .docx or .pdf. Local-first, runs in any browser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "test": "tsx test/docx.test.ts",
    "shots": "node scripts/shots.mjs"
  },
  "dependencies": {
    "docx": "^9.0.0",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "puppeteer-core": "^25.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
